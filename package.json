{
  "name": "azure-secret-manager",
  "version": "1.0.2",
  "description": "Tiny Azure Key Vault helper — get secrets with DefaultAzureCredential, caching, and a clean API.",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    }
  },
  "files": [
    "src",
    "types",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "test": "node --test tests/secrets.test.js",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "azure",
    "key-vault",
    "secrets",
    "keyvault",
    "credential",
    "devops",
    "cloud",
    "azure-keyvault",
    "key-vault-secrets",
    "secret-management",
    "azure-identity",
    "default-azure-credential",
    "nodejs",
    "security",
    "config"
  ],
  "author": "anilachary",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theinfyark/azure-secret-manager.git"
  },
  "bugs": {
    "url": "https://github.com/theinfyark/azure-secret-manager/issues"
  },
  "homepage": "https://github.com/theinfyark/azure-secret-manager#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@azure/identity": "^4.10.1",
    "@azure/keyvault-secrets": "^4.9.0"
  },
  "types": "./types/index.d.ts",
  "sideEffects": false,
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/anilachary"
  }
}
